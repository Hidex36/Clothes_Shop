@model IEnumerable<Clothes_shop.Models.Products>

@{
    Layout = "_Layout";
}

<div class="container-fluid px-4 py-5">
    <div class="d-flex justify-content-between align-items-end mb-4 pb-2 border-bottom">
        <div>
            <h1 class="fw-bolder display-6 text-dark mb-1">Quản Lý Sản Phẩm</h1>
        </div>
        <div>
            <a asp-area="Admin" asp-controller="Product" asp-action="Create" class="btn btn-primary btn-lg rounded-3 px-4 py-3 shadow d-flex align-items-center">
                <i class="bi bi-plus-circle-fill me-2"></i>
                <span class="fw-bold">THÊM MỚI SẢN PHẨM</span>
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="table-layout: fixed;">
                <thead class="bg-light border-bottom">
                    <tr class="text-primary text-uppercase sm">
                        <th class="py-3 fw-bold ps-4" style="width: 25%;">Tên Sản Phẩm</th>
                        <th class="py-3 fw-bold text-center" style="width: 15%;">Hình Ảnh</th>
                        <th class="py-3 fw-bold text-center" style="width: 15%;">Giá Bán</th>
                        <th class="py-3 fw-bold text-center" style="width: 15%;">Mô tả</th>
                        <th class="py-3 fw-bold text-center" style="width: 15%;">Số Lượng</th>
                        <th class="py-3 fw-bold text-center" style="width: 15%;">Danh Mục</th>
                        <th class="py-3 fw-bold text-center" style="width: 15%;">Thao Tác</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@item.Name</div>
                                </td>

                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" class="rounded-3 shadow-sm border"
                                             style="width: 60px; height: 60px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded-3 d-inline-flex align-items-center justify-content-center border"
                                             style="width: 60px; height: 60px;">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    }
                                </td>

                                <td class="text-center">
                                    <span class="text-danger fw-bold">
                                        @item.Price.ToString("#,##0") <u class="small">đ</u>
                                    </span>
                                </td>

                                <td class="text-center text-muted small" style="max-width: 200px;">
                                    <div class="text-truncate">@item.Description</div>
                                </td>

                                <td class="text-center">
                                    <span class="badge bg-secondary-subtle text-secondary border px-3">
                                        @item.quantity
                                    </span>
                                </td>

                                <td class="text-center">
                                    <span class="badge bg-primary-subtle text-primary border px-3">
                                        @(item.Category?.Name ?? "N/A")
                                    </span>
                                </td>

                                <td class="pe-4 text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning shadow-sm">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                              onsubmit="return confirm('Bạn muốn xóa sản phẩm: @item.Name không?');" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">Chưa có sản phẩm nào</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


<style>
    .table img {
        transition: transform 0.2s;
    }

        .table img:hover {
            transform: scale(1.5);
            z-index: 10;
            position: relative;
        }
</style>