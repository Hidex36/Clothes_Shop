@model Clothes_shop.Models.Products

@{
    Layout = "_Layout";
}

<div class="container-fluid px-4 py-4 bg-light">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h3 class="fw-bold text-dark mb-1">Thêm sản phẩm mới</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Sản phẩm</a></li>
                    <li class="breadcrumb-item active">Tạo mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <form asp-action="Create" method="post"  enctype="multipart/form-data">
        <div class="row g-4">

            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 h-100 mb-0">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-4 border-bottom pb-2">Thông tin chung</h5>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold text-secondary">Tên sản phẩm</label>
                            <input asp-for="Name" class="form-control border-2 shadow-none py-2" placeholder="Vui lòng nhập thên sản phẩm..." />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary">Giá niêm yết</label>
                                <div class="input-group">
                                    <input class="form-control border-2 shadow-none py-2" placeholder="0" />
                                    <span class="input-group-text bg-white border-2 border-start-0 text-muted">₫</span>
                                </div>
                                <span class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary">Số lượng nhập</label>
                                <input class="form-control border-2 shadow-none py-2" placeholder="0" />
                                <span class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CategoryId"  class="form-label fw-bold text-secondary">Danh mục sản phẩm</label>
                            <select asp-for="CategoryId" class="form-select border-2 shadow-none py-2" asp-items="ViewBag.CategoryId">
                                <option selected disabled>-- Chọn loại sản phẩm --</option>
                            </select>
                        </div>

                        <div class="mb-0">
                            <label class="form-label fw-bold text-secondary">Mô tả sản phẩm</label>
                            <textarea class="form-control border-2 shadow-none" rows="6" placeholder="Nhập mô tả sản phẩm tại đây..."></textarea>
                            <span class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 d-flex flex-column justify-content-between">
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-4 border-bottom pb-2">Hình ảnh</h5>

                        <div class="bg-light border border-2 border-dashed rounded-4 d-flex flex-column align-items-center justify-content-center p-5 text-center mb-3" style="border-style: dashed !important; height:250px">
                            <i class="bi bi-images text-muted mb-2" style="font-size: 3rem;"></i>
                            <p class="text-muted small">Ảnh sản phẩm sẽ hiển thị tại đây</p>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary small">Tải ảnh lên</label>
                            <input type="file" name="ImageFile" class="form-control form-control-sm border-2 shadow-none" accept="image/*" />
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4 bg-white">
                    <div class="card-body p-4">
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-3 fw-bold py-3 shadow-sm">
                                <i class="bi bi-plus-circle me-2"></i> THÊM SẢN PHẨM
                            </button>
                            <a asp-action="Index" class="btn btn-light border fw-semibold py-2">
                                Hủy bỏ
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </form>
</div>

