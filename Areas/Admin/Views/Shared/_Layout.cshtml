<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Clothes_shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Clothes_shop.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
    <partial name="HeaderAdmin" />
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-4 col-lg-2 d-md-block bg-white border-end vh-100 position-fixed p-0 shadow-sm">
                <div class="pt-4">
                    <div class="px-4 py-3 mb-2">
                        <span class="text-uppercase fw-bolder text-primary fs-4 border-bottom" style="letter-spacing: 2px;">Hệ Thống Quản Trị</span>
                    </div>

                    <div class="list-group list-group-flush">

                        <a asp-controller="Dashboard" asp-action="Index"
                           class="list-group-item list-group-item-action border-0 d-flex align-items-center py-4 px-4 fs-5 text-secondary">
                            <i class="bi bi-speedometer2 me-3 fs-4"></i>
                            <span class="fw-bold">Trang Chủ</span>
                            <i class="bi bi-chevron-right ms-auto fs-6 opacity-50"></i>
                        </a>

                        <a asp-controller="Categories" asp-action="Index"
                           class="list-group-item list-group-item-action border-0 d-flex align-items-center py-4 px-4 fs-5 text-secondary">
                            <i class="bi bi-grid-3x3-gap me-3 fs-4"></i>
                            <span class="fw-bold">Quản Lý Danh Mục</span>
                            <i class="bi bi-chevron-right ms-auto fs-6 opacity-50"></i>
                        </a>

                        <a asp-controller="Product" asp-action="Index"
                           class="list-group-item list-group-item-action border-0 d-flex align-items-center py-4 px-4 fs-5 text-secondary">
                            <i class="bi bi-box-seam me-3 fs-4"></i>
                            <span class="fw-bold">Quản Lý Sản Phẩm</span>
                            <i class="bi bi-chevron-right ms-auto fs-6 opacity-50"></i>
                        </a>

                        <a asp-controller="Order" asp-action="Index"
                           class="list-group-item list-group-item-action border-0 d-flex align-items-center py-4 px-4 fs-5 text-secondary">
                            <i class="bi bi-receipt me-3 fs-4"></i>
                            <span class="fw-bold">Danh Sách Đơn Đặt Hàng</span>
                            <i class="bi bi-chevron-right ms-auto fs-6"></i>
                        </a>

                        <a asp-controller="Employee" asp-action="Index"
                           class="list-group-item list-group-item-action border-0 d-flex align-items-center py-4 px-4 fs-5 text-secondary">
                            <i class="bi bi-person-badge me-3 fs-4"></i>
                            <span class="fw-bold">Quản lý Nhân sự</span>
                            <i class="bi bi-chevron-right ms-auto fs-6 opacity-50"></i>
                        </a>

                        <a asp-controller="Customer" asp-action="Index"
                           class="list-group-item list-group-item-action border-0 d-flex align-items-center py-4 px-4 fs-5 text-secondary">
                            <i class="bi bi-people me-3 fs-4"></i>
                            <span class="fw-bold">Khách Hàng</span>
                            <i class="bi bi-chevron-right ms-auto fs-6 opacity-50"></i>
                        </a>
                    </div>
                </div>
            </nav>

            <main class="col-md-8 ms-sm-auto col-lg-10 p-5" style="margin-left: 16.66%; background-color: #f8f9fa; min-height: 100vh;">
                <div class="card border-0 shadow-sm p-5 mt-3">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
