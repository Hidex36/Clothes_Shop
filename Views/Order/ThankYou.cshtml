@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="card shadow-sm border-0 py-5">
                <div class="card-body">
                    <div class="mb-4">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
                    </div>

                    <h1 class="fw-bold text-dark">Cám ơn bạn đã đặt hàng!</h1>
                    <p class="lead text-muted mb-4">
                        Đơn hàng của bạn đã được tiếp nhận và đang trong quá trình xử lý.
                        Chúng tôi sẽ liên hệ với bạn qua số điện thoại để xác nhận sớm nhất.
                    </p>

                    <div class="bg-light p-4 rounded-3 mb-4">
                        <h5 class="fw-bold mb-3">Thông tin hỗ trợ</h5>
                        <p class="mb-1"><i class="bi bi-telephone-fill me-2 text-primary"></i> Hotline: <strong>1900 1234</strong></p>
                        <p class="mb-0"><i class="bi bi-envelope-fill me-2 text-primary"></i> Email: support@clothesshop.com</p>
                    </div>

                    <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                        <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg px-4 gap-3">
                            Tiếp tục mua sắm
                        </a>
                        <a href="/" class="btn btn-outline-secondary btn-lg px-4">
                            Về trang chủ
                        </a>
                    </div>
                </div>
            </div>

            <p class="mt-4 text-muted small">
                Một email xác nhận chi tiết đơn hàng đã được gửi (giả định) đến bạn.
                Vui lòng kiểm tra hộp thư đến hoặc thư rác.
            </p>
        </div>
    </div>
</div>