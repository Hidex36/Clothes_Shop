@model Orders

@{
    var currentCart = ViewBag.Cart as Clothes_shop.Models.Cart ?? new Clothes_shop.Models.Cart();
}

<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-md-7">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h2 class="mb-4 fw-bold">
                        <i class="bi bi-credit-card-2-front me-2 text-primary"></i>Thông tin đặt hàng
                    </h2>
                    <hr />

                    <form asp-controller="Order" asp-action="CheckOut" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Name" class="fw-bold mb-1">Họ tên người nhận</label>
                            <input asp-for="Name" class="form-control form-control-lg" placeholder="Nhập tên đầy đủ..." required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="ShippingAddress" class="fw-bold mb-1">Địa chỉ giao hàng</label>
                            <input asp-for="ShippingAddress" class="form-control form-control-lg" placeholder="Số nhà, tên đường, phường/xã..." required />
                            <span asp-validation-for="ShippingAddress" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="ShippingPhone" class="fw-bold mb-1">Số điện thoại</label>
                            <input asp-for="ShippingPhone" class="form-control form-control-lg" placeholder="Số điện thoại liên hệ..." required />
                            <span asp-validation-for="ShippingPhone" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                                <i class="bi bi-bag-check-fill me-2"></i>Xác nhận đặt hàng
                            </button>
                            <a asp-controller="Cart" asp-action="Index" class="btn btn-link text-muted">
                                <i class="bi bi-arrow-left me-1"></i>Quay lại giỏ hàng
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm border-0 bg-light">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold">Đơn hàng của bạn (@(currentCart.Items.Count))</h5>
                </div>
                <div class="card-body">
                    @if (currentCart.Items.Any())
                    {
                        <ul class="list-group list-group-flush mb-3">
                            @foreach (var item in currentCart.Items)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center bg-transparent border-0 px-0">
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                        {
                                            <img src="@item.Product.ImageUrl" class="rounded border me-3" style="width: 50px; height: 50px; object-fit: cover;" />
                                        }
                                        <div>
                                            <h6 class="my-0 text-truncate" style="max-width: 180px;">@item.Product.Name</h6>
                                            <small class="text-muted">SL: @item.Quantity x @item.Product.Price.ToString("N0") đ</small>
                                        </div>
                                    </div>
                                    <span class="text-dark fw-medium">@((item.Product.Price * item.Quantity).ToString("N0")) đ</span>
                                </li>
                            }
                        </ul>

                        <div class="pt-3 border-top mt-2">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Tạm tính:</span>
                                <span>@currentCart.ComputeTotalValue().ToString("N0") đ</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Phí vận chuyển:</span>
                                <span class="text-success">Miễn phí</span>
                            </div>
                            <hr />
                            <div class="d-flex justify-content-between p-3 bg-white border rounded-3 shadow-sm">
                                <strong class="fs-5">Tổng cộng:</strong>
                                <strong class="fs-5 text-danger">@currentCart.ComputeTotalValue().ToString("N0") đ</strong>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-cart-x display-4 text-muted d-block mb-3"></i>
                            <p class="text-muted">Giỏ hàng đang trống.</p>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-primary">Tiếp tục mua sắm</a>
                        </div>
                    }
                </div>
            </div>

            <div class="mt-3 text-muted small px-2 text-center">
                <i class="bi bi-shield-lock me-1"></i> Thông tin của bạn luôn được bảo mật tuyệt đối.
            </div>
        </div>
    </div>
</div>