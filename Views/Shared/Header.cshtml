
<header class="shadow-sm sticky-top bg-white">
    <nav class="navbar navbar-expand-lg navbar-light py-3">
        <div class="container-fluid px-5">
            <a class="navbar-brand fw-bold fs-3 text-uppercase" href="#" style="letter-spacing: 1px;">
                CLO<span class="text-primary">THES</span> SHOP
            </a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a  asp-controller="Home" asp-action="Index"  class="nav-link active fw-semibold px-3" >Trang Chủ</a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Home" asp-action="About" class="nav-link fw-semibold px-3" >Giới Thiệu</a>
                    </li>
                    @await Component.InvokeAsync("CategoryMenu", new { isHeader = true })

                    <li class="nav-item">
                        <a asp-controller="Home" asp-action="Contact" class="nav-link fw-semibold px-3" >Liên Hệ</a>
                    </li>
                </ul>

                <div class="d-flex align-items-center gap-3">
                    <a href="#" class="text-dark position-relative">
                        <i class="bi bi-search fs-5"></i>
                    </a>
                    <a asp-controller="Cart" asp-action="Index" class="text-dark position-relative">
                        <i class="bi bi-cart fs-5"></i>
                        @await Component.InvokeAsync("CartBadge")
                    </a>
                    <a href="#" class="text-dark position-relative">
                        <i class="bi bi-person fs-5"></i>
                    </a>
                    
                </div>
            </div>
        </div>
    </nav>
</header>
