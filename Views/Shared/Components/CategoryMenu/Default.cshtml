@model IEnumerable<Categories> 


@if (ViewBag.IsHeader == true){

    <li class="nav-item dropdown custom-hover-menu">
        <a asp-controller="Product" asp-action="Index" class="nav-link fw-semibold px-3">
            Danh Mục Sản Phẩm
            <i class="bi bi-chevron-down ms-1 small"></i>
        </a>

        <div class="dropdown-menu border-0 shadow-lg p-3" style="min-width: 450px;">
            <div class="row">
                @foreach (var chunk in Model.Chunk(5))
                {
                    <div class="col-6">
                        <ul class="list-unstyled">
                            @foreach (var item in chunk)
                            {
                                <li>
                                    <a class="dropdown-item py-2" asp-controller="Product"
                                       asp-action="ProductByCategory" asp-route-categoryId="@item.Id">
                                        @item.Name
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    </li>
}
else
{
    <div class="list-group list-group-flush">
        <a asp-controller="Product"
           asp-action="Index"
           asp-route-categoryId=""
           class="list-group-item list-group-item-action">
            Tất cả sản phẩm
        </a>

        @foreach (var item in Model)
        {
            <a asp-controller="Product"
               asp-action="ProductByCategory"
               asp-route-categoryId="@item.Id"
               class="list-group-item list-group-item-action">
                @item.Name
            </a>
        }
    </div>
}

<style>
    /* 1. Thiết lập trạng thái mặc định cho Dropdown */
    .custom-hover-menu .dropdown-menu {
        display: block; /* Phải để block để có hiệu ứng mượt */
        opacity: 0;
        visibility: hidden;
        transform: translateY(15px);
        transition: all 0.3s ease-in-out;
        pointer-events: none; /* Ngăn chặn bấm nhầm khi đang ẩn */
        margin-top: 0;
    }

    /* 2. Hiệu ứng khi Hover */
    .custom-hover-menu:hover .dropdown-menu {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
        pointer-events: auto; /* Cho phép bấm khi đã hiện */
    }

    /* 3. Style cho các item bên trong để nổi bật hơn */
    .dropdown-item {
        transition: all 0.2s ease;
        border-radius: 4px;
    }

        .dropdown-item:hover {
            background-color: #f8f9fa;
            color: #007bff !important;
            padding-left: 20px; /* Hiệu ứng trượt chữ nhẹ khi hover */
        }

    /* Mẹo: Thêm một lớp đệm giả để chuột di chuyển từ nút xuống menu không bị mất hover */
    .custom-hover-menu::after {
        content: "";
        position: absolute;
        width: 100%;
        height: 20px;
        bottom: -20px;
        left: 0;
    }
</style>