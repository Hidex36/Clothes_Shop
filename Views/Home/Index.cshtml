@{
    ViewData["Title"] = "Trang Chủ";
	Layout = "_Layout";
}
<div id="heroCarousel" class="carousel slide mb-5" data-bs-ride="carousel">
    <div class="carousel-inner rounded-4 shadow-sm">
        <div class="carousel-item active">
            <div class="bg-dark text-white d-flex align-items-center" style="height: 500px; background: url('https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&w=1500&q=80') center/cover;">
                <div class="container py-5 text-center">
                    <h1 class="display-3 fw-bold">BST MÙA HÈ 2026</h1>
                    <p class="lead">Khám phá phong cách mới nhất với ưu đãi lên đến 50%.</p>
                    <a href="#new-arrivals" class="btn btn-light btn-lg px-4 rounded-pill fw-bold">MUA NGAY</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="row mb-5 text-center">
        <h2 class="fw-bold mb-4">Danh Mục Yêu Thích</h2>
        <div class="col-6 col-md-3">
            <div class="category-card p-4 bg-white rounded-4 shadow-sm border-0 transition">
                <i class="bi bi-gender-male fs-1 text-primary"></i>
                <h5 class="mt-3">Thời Trang Nam</h5>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="category-card p-4 bg-white rounded-4 shadow-sm border-0 transition">
                <i class="bi bi-gender-female fs-1 text-danger"></i>
                <h5 class="mt-3">Thời Trang Nữ</h5>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="category-card p-4 bg-white rounded-4 shadow-sm border-0 transition">
                <i class="bi bi-watch fs-1 text-warning"></i>
                <h5 class="mt-3">Phụ Kiện</h5>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="category-card p-4 bg-white rounded-4 shadow-sm border-0 transition">
                <i class="bi bi-emoji-smile fs-1 text-success"></i>
                <h5 class="mt-3">Trẻ Em</h5>
            </div>
        </div>
    </div>

    <div id="new-arrivals" class="mb-5">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <h2 class="fw-bold mb-0">Sản phẩm mới về</h2>
                <p class="text-muted">Cập nhật xu hướng mỗi ngày</p>
            </div>
            <a href="#" class="text-decoration-none fw-bold">Xem tất cả <i class="bi bi-arrow-right"></i></a>
        </div>

    
    </div>
</div>

<div class="bg-primary text-white py-5 mt-5 rounded-top-5">
    <div class="container text-center">
        <h3 class="fw-bold">Đăng ký nhận tin</h3>
        <p>Nhận mã giảm giá 10% cho đơn hàng đầu tiên của bạn!</p>
        <div class="row justify-content-center mt-3">
            <div class="col-md-6">
                <div class="input-group">
                    <input type="email" class="form-control rounded-start-pill border-0 px-4" placeholder="Email của bạn...">
                    <button class="btn btn-dark rounded-end-pill px-4">ĐĂNG KÝ</button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .category-card:hover {
        transform: translateY(-5px);
        background-color: #f8f9fa !important;
        cursor: pointer;
    }

    .product-card {
        transition: all 0.3s ease;
    }

        .product-card:hover {
            transform: scale(1.02);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .product-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.2);
        opacity: 0;
        transition: 0.3s ease;
    }

    .product-card:hover .product-overlay {
        opacity: 1;
    }

    .transition {
        transition: 0.3s;
    }
</style>

