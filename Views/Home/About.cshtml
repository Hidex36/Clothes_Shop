@{
    Layout = "_Layout";
    ViewData["Title"] = "Về chúng tôi";
}

<div class="about-page bg-white">

    <div class="position-relative overflow-hidden mb-5">
        <img src="~/images/about-banner.jpg" class="w-100 vh-60 object-fit-cover shadow-sm"
             style="height: 500px; filter: brightness(0.9);" alt="Về chúng tôi" />
        <div class="position-absolute top-50 start-50 translate-middle text-center text-white">
            <h1 class="display-3 fw-bold text-uppercase tracking-widest shadow-text">Our Story</h1>
            <p class="fs-5 fw-light">Định hình phong cách - Khẳng định chất riêng</p>
        </div>
    </div>

    <div class="container">
        <div class="row justify-content-center py-5">
            <div class="col-md-8 text-center">
                <h6 class="text-primary text-uppercase fw-bold mb-3" style="letter-spacing: 3px;">Hành trình của chúng tôi</h6>
                <h2 class="display-5 fw-bold mb-3 text-dark">Câu chuyện của Clothes Shop</h2>
                <p class="lead text-secondary ">
                    Chào mừng bạn đến với chúng tôi. Từ một cửa hàng nhỏ, chúng tôi đã không ngừng sáng tạo
                    để mang đến những giá trị tốt nhất thông qua sự tận tâm và gu thẩm mỹ khác biệt trong từng sản phẩm.
                </p>
            </div>
        </div>

        <div class="row text-center g-4 py-5">
            <div class="col-md-4">
                <div class="p-4 border-0 bg-light rounded-4 h-100 hover-lift">
                    <div class="icon-circle bg-white shadow-sm mx-auto mb-4">
                        <i class="bi bi-patch-check text-primary fs-3"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Chất lượng</h5>
                    <p class="text-muted small px-3">Luôn đặt tiêu chuẩn cao nhất cho mọi sản phẩm ra mắt khách hàng.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 border-0 bg-light rounded-4 h-100 hover-lift">
                    <div class="icon-circle bg-white shadow-sm mx-auto mb-4">
                        <i class="bi bi-heart text-danger fs-3"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Tận Tâm</h5>
                    <p class="text-muted small px-3">Mỗi khách hàng là một người bạn, chúng tôi luôn sẵn sàng lắng nghe.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 border-0 bg-light rounded-4 h-100 hover-lift">
                    <div class="icon-circle bg-white shadow-sm mx-auto mb-4">
                        <i class="bi bi-stars text-warning fs-3"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Sáng Tạo</h5>
                    <p class="text-muted small px-3">Không ngừng đổi mới để bắt kịp những xu hướng thời trang toàn cầu.</p>
                </div>
            </div>
        </div>

        <div class="row py-5 my-5 align-items-center">
            <div class="col-md-6 mb-4 mb-md-0">
                <div class="pe-lg-5">
                    <h3 class="display-6 fw-bold mb-4">Tầm nhìn & Sứ mệnh</h3>
                    <p class="fs-5 lh-base text-secondary mb-4">
                        Chúng tôi không chỉ bán quần áo, chúng tôi trao gửi niềm tin. Mục tiêu lớn nhất là trở thành
                        người bạn đồng hành tin cậy, giúp bạn tự tin tỏa sáng mỗi ngày.
                    </p>
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-check2-circle text-primary fs-4 me-3"></i>
                        <span class="fw-bold text-dark">Trung thực & Minh bạch</span>
                    </div>
                    <div class="d-flex align-items-center">
                        <i class="bi bi-check2-circle text-primary fs-4 me-3"></i>
                        <span class="fw-bold text-dark">Trách nhiệm với cộng đồng</span>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="position-relative p-2">
                    <div class="bg-primary position-absolute top-0 start-0 w-100 h-100 rounded-5 rotate-3 z-n1 opacity-10"></div>
                    <div class="p-5 bg-white rounded-5 shadow-sm border border-light">
                        <h4 class="fw-bold text-dark mb-3">Giá trị cốt lõi</h4>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-3 border-bottom pb-2 text-muted italic">"Sự hài lòng của bạn là thước đo thành công."</li>
                            <li class="mb-3 border-bottom pb-2 text-muted italic">"Luôn đi đầu trong xu hướng thiết kế."</li>
                            <li class="mb-0 text-muted italic">"Phát triển bền vững cùng môi trường."</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container pb-5">
        <div class="cta-box bg-dark p-5 text-center rounded-5 shadow-lg text-white">
            <h2 class="display-6 fw-bold mb-3">Sẵn sàng nâng tầm phong cách?</h2>
            <p class="fs-5 mb-4 opacity-75">Liên hệ với đội ngũ tư vấn của Clothes Shop ngay hôm nay.</p>
            <a asp-controller="Home" asp-action="Contact" class="btn btn-light btn-lg px-5 py-3 fw-bold rounded-pill shadow-sm hover-scale">
                LIÊN HỆ VỚI CHÚNG TÔI
            </a>
        </div>
    </div>
</div>

<style>
    /* CSS bổ trợ để tăng tính hài hòa */
    .icon-circle {
        width: 70px;
        height: 70px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }

    .hover-lift {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .hover-lift:hover {
            transform: translateY(-10px);
            background-color: #ffffff !important;
            box-shadow: 0 1rem 3rem rgba(0,0,0,0.1) !important;
        }

    .rotate-3 {
        transform: rotate(3deg);
    }

    .z-n1 {
        z-index: -1;
    }

    .shadow-text {
        text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
    }

    .hover-scale:hover {
        transform: scale(1.05);
        transition: 0.3s;
    }
</style>