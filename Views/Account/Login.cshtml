@model Clothes_shop.Models.ViewModels.LoginViewModel;

<div class="container d-flex justify-content-center py-5">

    <div class="row shadow-lg rounded-4 overflow-hidden w-100 bg-white border-0" style="max-width: 880px;">

        <div class="col-md-6 p-5">
            <div class="w-100">
                <h3 class="fw-bold mb-2 text-dark text-center">Đăng Nhập</h3>
                <p class="text-muted small text-center mb-4">Mừng bạn quay trở lại với Clothes_Shop!</p>

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label small fw-bold text-secondary mb-1">Địa chỉ Email</label>
                        <input asp-for="Email" type="email" class="form-control py-2 bg-light border-0"
                               style="border-bottom: 2px solid #eee !important; border-radius: 8px;" placeholder="Email của bạn">
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <label asp-for="Password" class="form-label small fw-bold text-secondary mb-1">Mật khẩu</label>
                            <a href="#" class="text-decoration-none small fw-bold" style="font-size: 0.75rem;">Quên mật khẩu?</a>
                        </div>
                        <input asp-for="Password" type="password" class="form-control py-2 bg-light border-0"
                               style="border-bottom: 2px solid #eee !important; border-radius: 8px;" placeholder="********">
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-sm rounded-3">
                        ĐĂNG NHẬP
                    </button>
                </form>

                <div class="text-center mt-4">
                    <small class="text-muted">Chưa có tài khoản? <a asp-controller="Account" asp-action="Register" class="text-decoration-none fw-bold text-primary">Đăng ký ngay</a></small>
                </div>
            </div>
        </div>

        <div class="col-md-6 d-none d-md-block position-relative p-0">
            <img src="https://images.unsplash.com/photo-1441984905746-18568b2177af?q=80&w=2070&auto=format&fit=crop"
                 class="w-100 h-100 object-fit-cover position-absolute" alt="Login Image">
            <div class="position-absolute w-100 h-100" style="background: rgba(0,0,0,0.5);"></div>
            <div class="position-relative z-1 h-100 d-flex flex-column justify-content-center p-5 text-white text-center">
                <h3 class="fw-bold mb-2 text-uppercase">Clothes Shop</h3>
                <div class="mx-auto bg-white mb-3" style="height: 2px; width: 50px;"></div>
                <p class="opacity-75">"Đăng nhập để nhận ngay ưu đãi mới nhất từ chúng mình."</p>
            </div>
        </div>
    </div>
</div>
