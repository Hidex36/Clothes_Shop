@model Clothes_shop.Models.ViewModels.RegisterViewmodel;

<div class="container d-flex justify-content-center py-5">

    <div class="row shadow-lg rounded-4 overflow-hidden w-100 bg-white border-0" style="max-width: 880px;">

        <div class="col-md-6 p-5">
            <div class="w-100">
                <h3 class="fw-bold mb-3 text-dark text-center">Đăng Ký</h3>
                <p class="text-muted small text-center mb-4">Tham gia cùng Clothes_Shop ngay!</p>

                <form asp-action="Register" method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary mb-1">Địa chỉ Email</label>
                        <input asp-for="Email" type="email" class="form-control py-2 bg-light border-0"
                               style="border-bottom: 2px solid #eee !important; border-radius: 8px;" placeholder="Email của bạn">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary mb-1">Mật khẩu</label>
                        <input asp-for="Password" type="password" class="form-control py-2 bg-light border-0"
                               style="border-bottom: 2px solid #eee !important; border-radius: 8px;" placeholder="********">
                    </div>
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-secondary mb-1">Xác nhận mật khẩu</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control py-2 bg-light border-0"
                               style="border-bottom: 2px solid #eee !important; border-radius: 8px;" placeholder="********">
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-sm rounded-3">
                        ĐĂNG KÝ TÀI KHOẢN
                    </button>
                </form>

                <div class="text-center mt-4">
                    <small class="text-muted">Đã có tài khoản? <a asp-controller="Account" asp-action="Login" class="text-decoration-none fw-bold text-primary">Đăng nhập ngay</a></small>
                </div>
            </div>
        </div>

        <div class="col-md-6 d-none d-md-block position-relative p-0">
            <img src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?q=80&w=2070&auto=format&fit=crop"
                 class="w-100 h-100 object-fit-cover position-absolute">
            <div class="position-absolute w-100 h-100" style="background: rgba(0,0,0,0.5);"></div>
            <div class="position-relative z-1 h-100 d-flex flex-column justify-content-center p-5 text-white text-center">
                <h3 class="fw-bold mb-2">CLOTHES SHOP</h3>
                <div class="mx-auto bg-white mb-3" style="height: 2px; width: 50px;"></div>
                <p class="opacity-75 italic">"Chất Riêng - Gu Đỉnh!"</p>
            </div>
        </div>
    </div>
</div>