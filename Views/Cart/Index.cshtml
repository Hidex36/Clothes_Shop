@model Clothes_shop.Models.Cart

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-cart3 text-primary me-2"></i>Giỏ hàng của bạn</h2>

        @if (Model.Items.Count > 0)
        {
            <a asp-action="Clear" class="btn btn-outline-danger btn-sm"
               onclick="return confirm('Bạn có chắc chắn muốn dọn sạch giỏ hàng?')">
                <i class="bi bi-trash3-fill me-1"></i> Xóa toàn bộ
            </a>
        }
    </div>

    @if (Model.Items.Count > 0)
    {
        <div class="row">
            <div class="col-md-9">
                <div class="card shadow-sm border-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-center">Giá</th>
                                <th class="text-center" style="width: 160px;">Số lượng</th>
                                <th class="text-end">Tổng</th>
                                <th class="text-center">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="@item.Product.ImageUrl" alt="@item.Product.Name"
                                                 style="width: 60px; height: 60px; object-fit: cover;" class="rounded me-3 border">
                                            <div>
                                                <span class="fw-bold d-block text-truncate" style="max-width: 250px;">@item.Product.Name</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">@item.Product.Price.ToString("N0")đ</td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center align-items-center">
                                            <form asp-controller="Cart" asp-action="Remove" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@item.Product.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-secondary px-2">
                                                    <i class="bi bi-dash"></i>
                                                </button>
                                            </form>

                                            <input type="text" class="form-control form-control-sm text-center mx-2"
                                                   value="@item.Quantity" style="width: 45px;" readonly>

                                            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@item.Product.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-secondary px-2">
                                                    <i class="bi bi-plus"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                    <td class="text-end text-success fw-bold">
                                        @((item.Product.Price * item.Quantity).ToString("N0"))đ
                                    </td>
                                    <td class="text-center">
                                        <form asp-controller="Cart" asp-action="RemoveLine" method="post">
                                            <input type="hidden" name="id" value="@item.Product.Id" />
                                            <button type="submit" class="btn btn-link text-danger p-0"
                                                    onclick="return confirm('Bạn muốn xóa sản phẩm này khỏi giỏ hàng?')">
                                                <i class="bi bi-trash3 fs-5"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title mb-3 fw-bold">Tóm tắt đơn hàng</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Tạm tính:</span>
                            <span class="fw-bold">@Model.Items.Sum(x => x.Product.Price * x.Quantity).ToString("N0")đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Giảm giá:</span>
                            <span class="text-success">0đ</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fw-bold">Tổng cộng:</span>
                            <span class="fs-5 fw-bold text-danger">
                                @Model.Items.Sum(x => x.Product.Price * x.Quantity).ToString("N0")đ
                            </span>
                        </div>
                        <div class="d-grid gap-2">
                            <a asp-controller="Order" asp-action="CheckOut" class="btn btn-primary btn-lg">
                                Thanh toán ngay
                            </a>
                            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i> Tiếp tục mua sắm
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 shadow-sm rounded bg-white border">
            <div class="mb-4">
                <i class="bi bi-bag-x display-1 text-light"></i>
            </div>
            <h3 class="fw-bold text-muted">Giỏ hàng của bạn đang trống</h3>
            <p class="text-muted mb-4">Có vẻ như bạn chưa thêm sản phẩm nào.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary px-5 py-2">
                <i class="bi bi-shop me-2"></i> Mua sắm ngay
            </a>
        </div>
    }
</div>